# ============================================
# FlowFinance - Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# -----------------------------------------------------------
# DATABASE (Required)
# -----------------------------------------------------------
# MySQL connection string
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/flowfinance"

# -----------------------------------------------------------
# CLERK AUTH (Required for web app)
# -----------------------------------------------------------
# Get these from https://clerk.com -> Your App -> API Keys
# Public key (starts with pk_test_ or pk_live_)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_YOUR_KEY_HERE"

# Secret key (starts with sk_test_ or sk_live_)
CLERK_SECRET_KEY="sk_test_YOUR_KEY_HERE"

# -----------------------------------------------------------
# TELEGRAM BOT (Required for Telegram bot)
# -----------------------------------------------------------
# 1. Talk to @BotFather on Telegram
# 2. Send /newbot and follow the steps
# 3. Copy the token (looks like: 123456789:ABCdefGHIjklMNOpqrsTUVwxyZ)
TELEGRAM_BOT_TOKEN="123456789:ABCdefGHIjklMNOpqrsTUVwxyZ"

# -----------------------------------------------------------
# OPTIONAL CONFIGURATION
# -----------------------------------------------------------
# Port for Next.js (default: 3000)
# PORT=3000

# Node environment (default: development)
# NODE_ENV=production
